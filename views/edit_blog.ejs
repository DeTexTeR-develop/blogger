<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Blog — Blogger</title>
    <%- include('./partials/head') %>
    <%- include('./partials/theme') %>
</head>
<body>
    <%- include('./partials/navbar') %>

    <div class="page-wrapper">
        <div class="container py-5" style="max-width: 780px;">

            <div class="mb-4">
                <h1 class="page-title mb-1">Edit Blog Post</h1>
                <p class="text-muted">Update your post below</p>
            </div>

            <% if (error) { %>
                <div class="alert alert-danger mb-4" role="alert"><%= error %></div>
            <% } %>

            <div class="form-card">
                <form action="/blogs/<%= blog.slug %>/edit" method="POST" enctype="multipart/form-data">
                    <div class="mb-4">
                        <label for="title" class="form-label">Title</label>
                        <input
                            type="text"
                            name="title"
                            id="title"
                            class="form-control"
                            value="<%= blog.title %>"
                            required
                        >
                    </div>
                    <div class="mb-4">
                        <label for="body" class="form-label">Content</label>
                        <textarea
                            name="body"
                            id="body"
                            class="form-control"
                            rows="12"
                            style="min-height: 280px; resize: vertical;"
                            required
                        ><%= blog.body %></textarea>
                    </div>
                    <div class="mb-4">
                        <label for="coverImage" class="form-label">Cover Image <span class="text-muted" style="font-size: 0.8rem;">(optional)</span></label>
                        <% if (blog.coverImage) { %>
                            <div class="mb-2">
                                <img src="<%= blog.coverImage %>" alt="Current cover" style="max-height: 160px; border-radius: 10px; object-fit: cover; width: 100%;">
                                <p class="text-muted mt-1 mb-0" style="font-size: 0.8rem;">Upload a new image to replace the current one</p>
                            </div>
                        <% } %>
                        <input
                            type="file"
                            name="coverImage"
                            id="coverImage"
                            class="form-control"
                            accept="image/*"
                        >
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <a href="/blogs/<%= blog.slug %>" class="btn btn-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                    </div>
                </form>
            </div>

        </div>
    </div>

    <%- include('./partials/scripts') %>
</body>
</html>
