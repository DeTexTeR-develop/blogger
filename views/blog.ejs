<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= blog.title %></title>
    <%- include('./partials/head') %>
</head>
<body>
    <%- include('./partials/navbar') %>

    <div class="container mt-5" style="max-width: 800px;">

        <h1 class="mb-2"><%= blog.title %></h1>

        <p class="text-muted mb-1">
            By <strong><%= blog.author.username %></strong>
        </p>
        <p class="text-muted small mb-4">
            Published <%= new Date(blog.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
        </p>

        <hr>

        <p class="mt-4" style="white-space: pre-wrap;"><%= blog.body %></p>

        <!-- Edit / Delete buttons — only visible to the author -->
        <% if (user && user.id === blog.author._id.toString()) { %>
            <div class="d-flex gap-2 mt-5">
                <a href="/blogs/<%= blog.slug %>/edit" class="btn btn-warning">Edit Blog</a>
                <button
                    type="button"
                    class="btn btn-danger"
                    data-bs-toggle="modal"
                    data-bs-target="#deleteModal"
                >
                    Delete Blog
                </button>
            </div>
        <% } %>

    </div>

    <!-- Delete confirmation modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Delete Blog Post</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete <strong><%= blog.title %></strong>?</p>
                    <p class="text-danger mb-0">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form action="/blogs/<%= blog.slug %>/delete" method="POST">
                        <button type="submit" class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <%- include('./partials/scripts') %>
</body>
</html>
