<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Blogs</title>
    <%- include('./partials/head') %>
</head>
<body>
    <%- include('./partials/navbar') %>

    <div class="container mt-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">All Blogs</h2>
            <% if (user) { %>
                <a href="/blogs/create" class="btn btn-primary">+ New Blog</a>
            <% } %>
        </div>

        <% if (blogs && blogs.length > 0) { %>
            <div class="row g-4">
                <% blogs.forEach(blog => { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body d-flex flex-column">

                                <h5 class="card-title">
                                    <a href="/blogs/<%= blog.slug %>" class="text-decoration-none">
                                        <%= blog.title %>
                                    </a>
                                </h5>

                                <p class="text-muted small mb-2">
                                    By <strong><%= blog.author.username %></strong>
                                    &middot;
                                    <%= new Date(blog.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                                </p>

                                <p class="card-text flex-grow-1">
                                    <%= blog.body.length > 200 ? blog.body.substring(0, 200) + '...' : blog.body %>
                                </p>

                                <a href="/blogs/<%= blog.slug %>" class="btn btn-sm btn-outline-primary mt-3 align-self-start">
                                    Read more
                                </a>

                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center mt-5">
                <p class="text-muted fs-5">No blogs have been published yet.</p>
                <% if (user) { %>
                    <a href="/blogs/create" class="btn btn-primary mt-2">Be the first to write one</a>
                <% } %>
            </div>
        <% } %>

    </div>

    <%- include('./partials/scripts') %>
</body>
</html>
