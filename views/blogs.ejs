<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Blogs — Blogger</title>
    <%- include('./partials/head') %>
    <%- include('./partials/theme') %>
</head>
<body>
    <%- include('./partials/navbar') %>

    <div class="page-wrapper">
        <div class="container py-5">

            <div class="d-flex justify-content-between align-items-center mb-5">
                <div>
                    <h1 class="page-title mb-1">All Blogs</h1>
                    <p class="text-muted mb-0">Explore stories from our community</p>
                </div>
                <% if (user) { %>
                    <a href="/blogs/create" class="btn btn-primary">+ New Blog</a>
                <% } %>
            </div>

            <% if (blogs && blogs.length > 0) { %>
                <div class="row g-4">
                    <% blogs.forEach(blog => { %>
                        <div class="col-md-6 col-lg-4">
                            <div class="glass-card h-100 d-flex flex-column" style="overflow: hidden;">
                                <% if (blog.coverImage) { %>
                                    <img src="<%= blog.coverImage %>" alt="<%= blog.title %>" style="width: 100%; height: 160px; object-fit: cover;">
                                <% } %>
                                <div class="p-4 d-flex flex-column flex-grow-1">
                                <h5 style="font-weight: 700; font-size: 1.05rem;">
                                    <a href="/blogs/<%= blog.slug %>" class="text-decoration-none" style="color: #e2e8f0;">
                                        <%= blog.title %>
                                    </a>
                                </h5>
                                <p class="text-muted small mb-3">
                                    By <strong style="color: #94a3b8;"><%= blog.author.username %></strong>
                                    &middot;
                                    <%= new Date(blog.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                                </p>
                                <p style="color: #94a3b8; font-size: 0.95rem; flex-grow: 1;">
                                    <%= blog.body.length > 200 ? blog.body.substring(0, 200) + '...' : blog.body %>
                                </p>
                                <a href="/blogs/<%= blog.slug %>" class="btn btn-outline-primary btn-sm mt-3 align-self-start">
                                    Read more →
                                </a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-5">
                    <div style="font-size: 3rem; margin-bottom: 1rem;">✍️</div>
                    <p style="color: #64748b; font-size: 1.1rem;">No blogs yet. Be the first to write one.</p>
                    <% if (user) { %>
                        <a href="/blogs/create" class="btn btn-primary mt-2">Write a Blog</a>
                    <% } else { %>
                        <a href="/user/sign-up" class="btn btn-primary mt-2">Get Started</a>
                    <% } %>
                </div>
            <% } %>

        </div>
    </div>

    <%- include('./partials/scripts') %>
</body>
</html>
